generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  // native: 로컬 개발 환경 (macOS, Windows, Linux)
  // GitHub Actions Ubuntu 환경을 위한 debian-openssl-3.0.x 추가
  // EC2 Amazon Linux 2023 환경을 위한 rhel-openssl-3.0.x 추가
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Models
// ============================================================================

/// 구매자 앱(web-user) 전용 계정 — 판매자 계정과 DB·토큰으로 완전 분리
model Consumer {
  id String @id @default(cuid())

  phone           String  @unique
  name            String?
  nickname        String?
  profileImageUrl String? @map("profile_image_url")
  isPhoneVerified Boolean @default(false) @map("is_phone_verified")
  isActive        Boolean @default(true) @map("is_active")
  withdrawReason  String? @map("withdraw_reason")
  withdrawnAt     DateTime? @map("withdrawn_at")

  googleId    String? @unique @map("google_id")
  googleEmail String? @map("google_email")

  createdAt   DateTime @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  productLikes       ProductLike[]
  storeLikes         StoreLike[]
  productRecentViews ProductRecentView[]
  reviews            ProductReview[]
  chatRooms          ChatRoom[]
  orders             Order[]
  consumerNotifications UserNotification[]

  @@index([phone])
  @@index([googleId])
  @@map("consumers")
}

/// 판매자 앱(web-seller) 전용 계정
model Seller {
  id String @id @default(cuid())

  phone           String  @unique
  name            String?
  nickname        String?
  profileImageUrl String? @map("profile_image_url")
  isPhoneVerified Boolean @default(false) @map("is_phone_verified")
  isActive        Boolean @default(true) @map("is_active")
  withdrawReason  String? @map("withdraw_reason")
  withdrawnAt     DateTime? @map("withdrawn_at")

  googleId    String? @unique @map("google_id")
  googleEmail String? @map("google_email")

  /// 판매자 온보딩·검증 단계 (스토어 생성 후 갱신)
  sellerVerificationStatus SellerVerificationStatus @default(REGISTERED) @map("seller_verification_status")

  createdAt   DateTime @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  stores                  Store[]
  sellerNotifications     UserNotification[]
  notificationPreferences UserNotificationPreference[]

  @@index([phone])
  @@index([googleId])
  @@map("sellers")
}

// Phone verification for registration and password recovery
model PhoneVerification {
  // Primary Key
  id String @id @default(cuid())

  // 비즈니스 필드
  phone            String // 휴대폰 번호
  verificationCode String @map("verification_code") // 인증 코드
  expiresAt        DateTime @map("expires_at") // 만료 시간
  isVerified       Boolean @default(false) @map("is_verified") // 인증 여부
  purpose          String @default("registration") // 목적 (registration 등)

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("phone_verifications")
}

// Product model for product management
model Product {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  storeId String @map("store_id") // 스토어 ID

  // 비즈니스 필드 - 기본 정보
  name              String // 상품명 (필수)
  images            String[] @default([]) // 상품 이미지 목록 (첫 번째 요소가 대표 이미지)
  salePrice         Int @map("sale_price") // 판매 가격
  salesStatus       EnableStatus @map("sales_status") // 판매 상태
  visibilityStatus  EnableStatus @map("visibility_status") // 노출 상태
  productType           ProductType @default(BASIC_CAKE) @map("product_type") // 상품 타입 (기본/커스텀)
  productCategoryTypes  ProductCategoryType[] @default([]) @map("product_category_types") // 상품 카테고리 타입 (없거나 여러 개)
  searchTags            String[] @default([]) @map("search_tags") // 검색 태그 (없거나 여러 개)
  detailDescription     String? @map("detail_description") // 상세 설명

  // 비즈니스 필드 - 케이크 옵션
  cakeSizeOptions   Json? @map("cake_size_options") // 케이크 사이즈 옵션
  cakeFlavorOptions  Json? @map("cake_flavor_options") // 케이크 맛 옵션
  letteringVisible   EnableStatus @map("lettering_visible") // 레터링 표시 여부
  letteringRequired OptionRequired @map("lettering_required") // 레터링 필수 여부
  letteringMaxLength Int @map("lettering_max_length") // 레터링 최대 길이
  imageUploadEnabled EnableStatus @map("image_upload_enabled") // 이미지 업로드 가능 여부

  // 비즈니스 필드 - 고시정보 (식품 판매 시 법적 필수 항목)
  productNumber              String @map("product_number") // 상품번호 (백엔드 자동 생성)
  productNoticeFoodType      String @map("product_notice_food_type") // 식품의 유형
  productNoticeProducer      String @map("product_notice_producer") // 제조사
  productNoticeOrigin        String @map("product_notice_origin") // 원산지
  productNoticeAddress       String @map("product_notice_address") // 소재지
  productNoticeManufactureDate String @map("product_notice_manufacture_date") // 제조연월일
  productNoticeExpirationDate  String @map("product_notice_expiration_date") // 소비기한 또는 품질유지기한
  productNoticePackageCapacity String @map("product_notice_package_capacity") // 포장단위별 용량/수량
  productNoticePackageQuantity String @map("product_notice_package_quantity") // 포장 단위별 수량
  productNoticeIngredients     String @map("product_notice_ingredients") // 원재료명 및 함량
  productNoticeCalories        String @map("product_notice_calories") // 영양성분
  productNoticeSafetyNotice    String @map("product_notice_safety_notice") // 소비자안전을 위한 주의사항
  productNoticeGmoNotice       String @map("product_notice_gmo_notice") // 유전자변형식품에 해당하는 경우의 표시
  productNoticeImportNotice     String @map("product_notice_import_notice") // 수입식품의 경우
  productNoticeCustomerService String @map("product_notice_customer_service") // 고객센터

  // 시스템 필드
  likeCount Int      @default(0) @map("like_count") // 좋아요 개수
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  likes       ProductLike[]
  recentViews ProductRecentView[]
  reviews     ProductReview[]
  orders      Order[]

  // 인덱스 최적화
  @@index([storeId]) // 스토어별 상품 조회
  @@index([visibilityStatus, salesStatus, createdAt(sort: Desc)]) // 노출된 상품 목록 조회 최적화 (정렬: 최신순)
  @@index([visibilityStatus, salesStatus, salePrice]) // 노출된 상품 목록 조회 최적화 (정렬: 가격순)
  @@index([visibilityStatus, salesStatus, likeCount(sort: Desc)]) // 노출된 상품 목록 조회 최적화 (정렬: 인기순)
  @@index([name]) // 상품명 검색 최적화
  @@map("products")
}

// Product like model
model ProductLike {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  consumerId String @map("consumer_id")
  productId  String @map("product_id")

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([consumerId, productId])
  @@index([consumerId])
  @@index([productId])
  @@map("product_likes")
}

// Store model for seller store information
model Store {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  sellerId String @map("seller_id")

  // 비즈니스 필드 - 스토어 정보
  logoImageUrl String? @map("logo_image_url") // 스토어 로고 이미지 URL
  name         String // 스토어명
  description  String? // 스토어 설명
  phoneNumber  String? @map("phone_number") // 스토어 연락처 (전화/휴대폰)

  // 비즈니스 필드 - 주소/위치 정보 (카카오지도 활용용)
  address      String? // 지번 주소 (예: "서울특별시 강남구 역삼동 456-789")
  roadAddress  String? // 도로명 주소 (예: "서울특별시 강남구 테헤란로 123")
  detailAddress String? // 상세주소 (예: "101호", "지하 1층")
  zonecode     String? // 우편번호
  latitude     Float? // 위도 (카카오지도 마커 표시 및 거리 계산용)
  longitude    Float? // 경도 (카카오지도 마커 표시 및 거리 계산용)

  // 비즈니스 필드 - 사업자 정보 (1단계 - 사용자 입력값만 저장)
  businessNo        String @map("business_no") // 사업자등록번호
  representativeName String @map("representative_name") // 대표자명
  openingDate       String @map("opening_date") // 개업일자
  businessName      String @map("business_name") // 사업자명
  businessSector    String @map("business_sector") // 업종
  businessType      String @map("business_type") // 업태

  // 비즈니스 필드 - 통신판매사업자 정보 (2단계 - 사용자 입력값만 저장)
  permissionManagementNumber String @map("permission_management_number") // 인허가관리번호 (통신판매사업자 신고번호)

  // 비즈니스 필드 - 정산 계좌
  bankAccountNumber String?         @map("bank_account_number") // 계좌번호
  bankName          StoreBankName? @map("bank_name") // 은행 코드
  accountHolderName String?         @map("account_holder_name") // 예금주명

  // 비즈니스 필드 - 채널 정보
  kakaoChannelId String? @map("kakao_channel_id") // 카카오채널 ID
  instagramId    String? @map("instagram_id") // 인스타그램 ID

  // 비즈니스 필드 - 영업 캘린더 (판매자 설정, Asia/Seoul 기준)
  /** 정기 휴무 요일 (0=일 … 6=토, 프론트 Date.getDay()와 동일) */
  weeklyClosedWeekdays Int[] @default([]) @map("weekly_closed_weekdays")
  /** 표준 영업 시작 HH:mm (30분 단위). 00:00+00:00이면 하루 전체 영업 */
  standardOpenTime  String @default("00:00") @map("standard_open_time") @db.VarChar(5)
  /** 표준 영업 종료 HH:mm. 00:00+00:00이면 하루 전체, 그 외는 픽업 [시작, 종료) */
  standardCloseTime String @default("00:00") @map("standard_close_time") @db.VarChar(5)
  /** 날짜별 예외 [{ date: "YYYY-MM-DD", isOpen, openTime?, closeTime? }] */
  businessCalendarOverrides Json @default("[]") @map("business_calendar_overrides")

  // 시스템 필드
  likeCount Int      @default(0) @map("like_count") // 좋아요 개수
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  seller    Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products  Product[]
  likes     StoreLike[]
  chatRooms ChatRoom[]
  feeds     StoreFeed[]
  orders    Order[]
  notificationPreferences UserNotificationPreference[]

  @@unique([sellerId, businessNo, permissionManagementNumber])
  @@index([sellerId])
  @@index([businessNo])
  @@index([likeCount])
  @@index([latitude, longitude]) // 위치 기반 검색을 위한 인덱스
  @@map("stores")
}

// Product recent view model
model ProductRecentView {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  consumerId String @map("consumer_id")
  productId  String @map("product_id")

  // 시스템 필드
  viewedAt DateTime @default(now()) @map("viewed_at") // 마지막 조회 시간

  // Relations
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 인덱스 최적화
  @@unique([consumerId, productId])
  @@index([consumerId, viewedAt(sort: Desc)])
  @@index([productId])
  @@map("product_recent_views")
}

// Store like model
model StoreLike {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  consumerId String @map("consumer_id")
  storeId    String @map("store_id")

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([consumerId, storeId])
  @@index([consumerId])
  @@index([storeId])
  @@map("store_likes")
}

// Product review model
model ProductReview {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  productId  String @map("product_id")
  consumerId String @map("consumer_id")
  /** 마이페이지에서 주문 기준으로 작성한 후기인 경우 연결 (주문당 최대 1건) */
  orderId    String? @unique @map("order_id")

  // 비즈니스 필드
  rating    Float // 별점 (0.0 ~ 5.0)
  content   String // 후기 내용
  imageUrls String[] @default([]) @map("image_urls") // 후기 이미지 URL 목록

  /** 사용자 삭제 시각. null이면 노출 대상(주문 재작성 불가는 이 행이 orderId를 유지한 채로 남는 것으로 표현) */
  deletedAt DateTime? @map("deleted_at")

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // 인덱스 최적화
  @@index([productId, createdAt(sort: Desc)]) // 상품별 후기 목록 조회 최적화 (최신순)
  @@index([productId, rating(sort: Desc), createdAt(sort: Desc)], map: "product_reviews_product_id_rating_desc_created_at_idx") // 상품별 후기 목록 조회 최적화 (별점 내림차순)
  @@index([productId, rating(sort: Asc), createdAt(sort: Desc)], map: "product_reviews_product_id_rating_asc_created_at_idx") // 상품별 후기 목록 조회 최적화 (별점 오름차순)
  @@index([consumerId]) // 사용자별 후기 조회
  @@map("product_reviews")
}

// ChatRoom model for user-store chat
model ChatRoom {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  consumerId String @map("consumer_id")
  storeId    String @map("store_id")

  // 비즈니스 필드
  lastMessage   String? @map("last_message") @db.VarChar(1000) // 마지막 메시지 미리보기용 (최대 1000자)
  lastMessageAt DateTime? @map("last_message_at") // 마지막 메시지 시간
  userUnread    Int @default(0) @map("user_unread") // 사용자 읽지 않은 메시지 개수
  storeUnread   Int @default(0) @map("store_unread") // 스토어 읽지 않은 메시지 개수

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([consumerId, storeId]) // 1대1 채팅방 보장
  @@index([consumerId, lastMessageAt(sort: Desc)]) // 사용자 채팅방 목록 조회 최적화
  @@index([storeId, lastMessageAt(sort: Desc)]) // 판매자 채팅방 목록 조회 최적화
  @@index([consumerId]) // 기존 인덱스 유지
  @@index([storeId]) // 기존 인덱스 유지
  @@map("chat_rooms")
}

// Message model for chat messages
model Message {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  roomId String @map("room_id") // 채팅방 ID

  // 비즈니스 필드
  text       String @db.Text // 메시지 내용
  senderId   String @map("sender_id") // 발신자 ID
  senderType MessageSenderType @map("sender_type") // 발신자 타입 (USER, STORE)

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt(sort: Desc)]) // 메시지 목록 조회 최적화
  @@index([roomId]) // 기존 인덱스 유지 (다른 쿼리에서 사용 가능)
  @@map("messages")
}

// Store feed model for store feed posts
model StoreFeed {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  storeId String @map("store_id") // 스토어 ID

  // 비즈니스 필드
  title   String // 피드 제목
  content String @db.Text // 피드 내용 (HTML 에디터 형식)

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // 인덱스 최적화
  @@index([storeId, createdAt(sort: Desc)]) // 스토어별 피드 목록 조회 최적화 (최신순)
  @@map("store_feeds")
}

// Order model for order management
// 하나의 주문(Order)은 하나의 상품(productId)에 대한 주문이지만,
// 여러 개의 주문 항목(OrderItem)을 가질 수 있습니다.
// 각 OrderItem은 서로 다른 옵션 조합(사이즈, 맛 등)을 가질 수 있습니다. 픽업 날짜는 주문 전체에 대해 하나로 고정됩니다.
model Order {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  consumerId String @map("consumer_id")
  productId  String @map("product_id")
  storeId    String @map("store_id")
  storeName String? @map("store_name") // 스토어명 (주문 시점의 스토어명 보존)
  productName  String? @map("product_name") // 상품명 (주문 시점의 상품명 보존)
  productImages String[] @default([]) @map("product_images") // 상품 이미지 (주문 시점의 상품 이미지 보존)

  // 비즈니스 필드 - 주문 기본 정보
  orderNumber   String @unique @map("order_number") // 주문 번호 (사용자에게 보여줄 번호, 예: ORD-20240101-001)
  totalQuantity Int @map("total_quantity") // 총 수량
  totalPrice     Int @map("total_price") // 총 금액

  // 비즈니스 필드 - 픽업 정보
  pickupDate         DateTime? @map("pickup_date") // 픽업 날짜 및 시간 (주문 전체에 대해 하나로 고정)
  pickupAddress      String? @map("pickup_address") // 픽업 주소 (지번 주소, 예: "서울특별시 강남구 역삼동 456-789")
  pickupRoadAddress  String? @map("pickup_road_address") // 픽업 주소 (도로명 주소, 예: "서울특별시 강남구 테헤란로 123")
  pickupDetailAddress String? @map("pickup_detail_address") // 픽업 상세주소 (예: "101호", "지하 1층")
  pickupZonecode     String? @map("pickup_zonecode") // 픽업 장소 우편번호
  pickupLatitude     Float? @map("pickup_latitude") // 픽업 장소 위도
  pickupLongitude    Float? @map("pickup_longitude") // 픽업 장소 경도

  // 비즈니스 필드 - 주문 상태
  orderStatus OrderStatus @default(RESERVATION_REQUESTED) @map("order_status") // 주문 상태
  /** 입금대기로 전환된 시각(입금 유효 기준 시작). 예약신청만 있을 때는 null */
  paymentPendingAt DateTime? @map("payment_pending_at")
  /** 입금 마감 시각(픽업까지 남은 시간에 따라 12h/6h/1h 티어 및 픽업 시각과의 min). 입금대기가 아니면 null */
  paymentPendingDeadlineAt DateTime? @map("payment_pending_deadline_at")
  /** 사용자가 입금완료 처리 시 입력한 입금자명 */
  depositorName String? @map("depositor_name")
  /** 입금 전 사용자 취소 시 입력한 사유 (자동 만료 취소 등은 null) */
  userCancelReason String? @map("user_cancel_reason") @db.Text
  /** 판매자가 입금대기에서 예약 취소(취소완료) 시 입력한 사유 */
  sellerCancelReason String? @map("seller_cancel_reason") @db.Text
  /** 판매자가 픽업대기에서 노쇼 처리 시 입력한 사유 */
  sellerNoShowReason String? @map("seller_no_show_reason") @db.Text
  /** 판매자가 취소환불대기로 전환할 때 입력한 사유 (사용자 요청 사유 `refundRequestReason`과 별도) */
  sellerCancelRefundPendingReason String? @map("seller_cancel_refund_pending_reason") @db.Text
  /** 입금 이후 사용자 취소·환불 요청 시 사유 */
  refundRequestReason String? @map("refund_request_reason") @db.Text
  /** 환불 받을 은행 (스토어 정산 계좌와 동일 `StoreBankName`) */
  refundBankName StoreBankName? @map("refund_bank_name")
  refundBankAccountNumber String? @map("refund_bank_account_number")
  refundAccountHolderName String? @map("refund_account_holder_name")

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store    Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  review     ProductReview?

  // 인덱스 최적화
  @@index([consumerId, createdAt(sort: Desc)]) // 사용자별 주문 목록 조회 최적화 (최신순)
  @@index([storeId, createdAt(sort: Desc)]) // 스토어별 주문 목록 조회 최적화 (최신순)
  @@index([productId]) // 상품별 주문 조회
  @@index([orderStatus]) // 주문 상태별 조회
  @@index([orderStatus, paymentPendingDeadlineAt]) // 입금대기 만료 배치
  @@index([orderNumber]) // 주문 번호로 조회
  @@index([pickupDate]) // 픽업 예정/지난 예약 필터
  @@index([pickupLatitude, pickupLongitude]) // 위치 기반 검색을 위한 인덱스
  @@map("orders")
}

/// 계정 단위 알림 (USER_WEB: consumerId / SELLER_WEB: sellerId)
model UserNotification {
  id         String                 @id @default(cuid())
  consumerId String?                @map("consumer_id")
  sellerId   String?                @map("seller_id")
  appSurface NotificationAppSurface @map("app_surface")
  category   NotificationCategory
  title      String
  body       String                 @db.Text
  readAt     DateTime?              @map("read_at")
  storeId    String?                @map("store_id")
  orderId    String?                @map("order_id")
  createdAt  DateTime               @default(now()) @map("created_at")

  consumer Consumer? @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  seller   Seller?   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([consumerId, appSurface, storeId, createdAt(sort: Desc)])
  @@index([sellerId, appSurface, storeId, createdAt(sort: Desc)])
  @@index([consumerId, appSurface, readAt])
  @@index([sellerId, appSurface, readAt])
  @@map("user_notifications")
}

/// 알림 설정 (판매자 웹: 판매자·스토어·표면 조합별)
model UserNotificationPreference {
  id                             String                 @id @default(cuid())
  sellerId                       String                 @map("seller_id")
  storeId                        String                 @map("store_id")
  appSurface                     NotificationAppSurface @map("app_surface")
  orderNotificationsEnabled     Boolean @default(true) @map("order_notifications_enabled")
  orderNotificationSoundEnabled Boolean @default(true) @map("order_notification_sound_enabled")
  updatedAt                      DateTime               @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([sellerId, appSurface, storeId])
  @@index([storeId])
  @@map("user_notification_preferences")
}

// OrderItem model for order items
// 하나의 주문(Order)에 여러 개의 주문 항목(OrderItem)이 포함될 수 있습니다.
// 각 OrderItem은 독립적인 옵션 조합을 가지며, 서로 다른 사이즈, 맛 등을 가질 수 있습니다.
model OrderItem {
  // Primary Key
  id String @id @default(cuid())

  // 관계 필드
  orderId String @map("order_id") // 주문 ID (하나의 Order에 여러 OrderItem이 연결됨)

  // 비즈니스 필드 - 주문 항목 정보
  // 각 OrderItem은 독립적인 옵션 조합을 가집니다
  // 사이즈 옵션 정보
  sizeId          String? @map("size_id") // 선택한 사이즈 옵션 ID
  sizeDisplayName String? @map("size_display_name") // 선택한 사이즈 표시명 (예: "도시락", "미니", "1호")
  sizeLengthCm    Int? @map("size_length_cm") // 선택한 사이즈 길이 (cm 단위)
  sizeDescription String? @map("size_description") // 선택한 사이즈 설명
  sizePrice       Int? @map("size_price") // 사이즈 추가 가격
  // 맛 옵션 정보
  flavorId        String? @map("flavor_id") // 선택한 맛 옵션 ID
  flavorDisplayName String? @map("flavor_display_name") // 선택한 맛 표시명 (예: "초콜릿", "바닐라")
  flavorPrice     Int? @map("flavor_price") // 맛 추가 가격
  letteringMessage String? @map("lettering_message") @db.VarChar(500) // 레터링 메시지 (최대 500자)
  requestMessage   String? @map("request_message") @db.Text // 요청 사항
  quantity         Int // 수량
  itemPrice        Int @map("item_price") // 개별 항목 가격 (기본 가격 + 사이즈 추가 가격 + 맛 추가 가격)
  imageUrls        String[] @default([]) @map("image_urls") // 업로드한 이미지 URL 목록 (커스텀 케이크용)

  // 시스템 필드
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // 인덱스 최적화
  @@index([orderId]) // 주문별 주문 항목 조회
  @@map("order_items")
}

